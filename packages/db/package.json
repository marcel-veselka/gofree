{
  "name": "@gofree/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "db:generate": "prisma generate --schema=prisma/schema",
    "db:push": "dotenv -e ../../.env.local -- prisma db push --schema=prisma/schema",
    "db:migrate": "dotenv -e ../../.env.local -- prisma migrate deploy --schema=prisma/schema",
    "db:migrate:dev": "dotenv -e ../../.env.local -- prisma migrate dev --schema=prisma/schema",
    "db:seed": "dotenv -e ../../.env.local -- tsx prisma/seed.ts",
    "db:studio": "dotenv -e ../../.env.local -- prisma studio --schema=prisma/schema",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.0.2",
    "@prisma/adapter-neon": "^7.5.0",
    "@prisma/client": "^6.0.0",
    "ws": "^8.19.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@gofree/config": "workspace:*",
    "@gofree/core": "workspace:*",
    "dotenv-cli": "^11.0.0",
    "prisma": "^6.0.0",
    "tsx": "^4.0.0"
  }
}
