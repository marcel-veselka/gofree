enum RunStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

enum RunType {
  CHAT
  AGENT
  TOOL
  TEST
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
  TOOL
}

model Run {
  id          String    @id @default(cuid())
  projectId   String
  userId      String
  status      RunStatus @default(PENDING)
  type        RunType
  model       String?
  startedAt   DateTime?
  completedAt DateTime?
  error       String?
  tokenUsage        Json?
  testSuiteId       String?
  environmentId     String?
  agentDefinitionId String?
  createdAt         DateTime  @default(now())

  project         Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  testSuite       TestSuite?       @relation(fields: [testSuiteId], references: [id])
  environment     TestEnvironment? @relation(fields: [environmentId], references: [id])
  agentDefinition AgentDefinition? @relation(fields: [agentDefinitionId], references: [id])
  steps           RunStep[]
  artifacts       RunArtifact[]
  logs            RunLog[]
  comments        Comment[]
  testResults     TestResult[]

  @@index([projectId, status])
  @@index([userId])
  @@index([testSuiteId])
  @@map("runs")
}

model RunStep {
  id      String @id @default(cuid())
  runId   String
  index   Int
  type    String
  input   Json?
  output  Json?
  error   String?
  startedAt   DateTime?
  completedAt DateTime?

  run Run @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId])
  @@map("run_steps")
}

model RunArtifact {
  id          String @id @default(cuid())
  runId       String
  name        String
  mimeType    String
  content     String?
  storagePath String?
  sizeBytes   Int?
  createdAt   DateTime @default(now())

  run Run @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId])
  @@map("run_artifacts")
}

model RunLog {
  id        String   @id @default(cuid())
  runId     String
  level     String
  message   String
  metadata  Json?
  createdAt DateTime @default(now())

  run Run @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId, createdAt])
  @@map("run_logs")
}

model Conversation {
  id        String   @id @default(cuid())
  projectId String
  userId    String
  title     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project  Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  messages Message[]

  @@index([projectId])
  @@map("conversations")
}

model Message {
  id             String      @id @default(cuid())
  conversationId String
  role           MessageRole
  content        String
  toolCalls      Json?
  tokenUsage     Json?
  createdAt      DateTime    @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@map("messages")
}

model McpConnection {
  id          String  @id @default(cuid())
  projectId   String
  name        String
  serverUrl   String
  transport   String  @default("sse")
  config      Json?
  enabled     Boolean @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, name])
  @@map("mcp_connections")
}
