{
  "name": "gofree",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "db:push": "pnpm --filter @gofree/db db:push",
    "db:migrate": "pnpm --filter @gofree/db db:migrate",
    "db:seed": "pnpm --filter @gofree/db db:seed",
    "db:generate": "pnpm --filter @gofree/db db:generate",
    "db:studio": "pnpm --filter @gofree/db db:studio",
    "clean": "turbo clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.0.3",
    "playwright": "^1.58.2",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "turbo": "^2.8.18",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1"
  }
}
